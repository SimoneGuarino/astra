{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "personal_ai",
    "version": "0.1.0",
    "identifier": "simone",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Astra",
                "width": 420,
                "height": 720,
                "minWidth": 360,
                "minHeight": 520,
                "decorations": false,
                "transparent": true,
                "resizable": true,
                "alwaysOnTop": true,
                "skipTaskbar": false,
                "center": false
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "**"
                ]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}